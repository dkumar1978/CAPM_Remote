{
  "xsappname": "mycapapp",
  "scopes": [
    {
      "name": "$XSAPPNAME.Display",
      "description": "display"
    },
    {
      "name": "$XSAPPNAME.Edit",
      "description": "edit"
    },
    {
      "name": "$XSAPPNAME.Delete",
      "description": "delete"
    },
    {
      "name": "$XSAPPNAME.Viewer",
      "description": "Viewer"
    },
    {
      "name": "$XSAPPNAME.Editor",
      "description": "Editor"
    }
  ],
  "attributes": [
    {
      "name": "bankName",
      "description": "Bank name which will control row level security",
      "valueType": "string"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "View all books",
      "default-role-name": "Viewer: Authorized to Read All Books",
      "scope-references": [
        "$XSAPPNAME.Display"
      ],
      "attribute-references": [
        {
          "name": "bankName"
        }
      ]
    },
    {
      "name": "Editor",
      "description": "Edit, delete PO and employee data",
      "scope-references": [
        "$XSAPPNAME.Edit",
        "$XSAPPNAME.Delete"
      ]
    }
  ],
  "authorities": [
    "$ACCEPT_GRANTED_AUTHORITIES"
  ],
  "oauth2-configuration": {
    "token-validity": 9000,
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com"
    ]
  },
  "xsenableasyncservice": "true"
}
